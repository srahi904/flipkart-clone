{
  "name": "flipkart-clone",
  "version": "1.0.0",
  "description": "Full-stack Flipkart clone assignment monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:push": "npm run prisma:push --workspace backend",
    "prisma:seed": "npm run prisma:seed --workspace backend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "packageManager": "npm@11.7.0"
}
